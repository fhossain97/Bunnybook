es":"116","suppressedMessages":"117","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"53"},{"filePath":"118","messages":"119","suppressedMessages":"120","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"53"},{"filePath":"121","messages":"122","suppressedMessages":"123","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"124","messages":"125","suppressedMessages":"126","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/index.js",[],[],[],"/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/reportWebVitals.js",[],[],"/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/App.js",[],[],[],"/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/utils/userService.jsx",[],[],"/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/utils/tokenService.jsx",[],[],"/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/seeds/Seeds.jsx",[],[],"/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/components/Layout.jsx",[],[],"/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/pages/PostEdit.jsx",[],[],"/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/pages/PostView.jsx",[],[],"/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/pages/Login/Login.jsx",[],[],"/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/pages/Register/Register.jsx",["127"],[],"import React, { useState } from \"react\";\nimport { useNavigate, Link } from \"react-router-dom\";\nimport userService from \"../../utils/userService\";\nimport '../Login/Login.css'\n\nconst Register = ({ handleSignupOrLogin }) => {\n  const navigate = useNavigate();\n  const [formData, setFormData] = useState({\n    username: \"\",\n    email: \"\",\n    password: \"\",\n    password_confirmation: \"\",\n  });\n\n  const handleChange = (e) => {\n    setFormData({ ...formData, [e.target.id]: e.target.value });\n  };\n\n  const handleSubmit = async (e) => {\n    e.preventDefault();\n    try {\n      await userService.signup(formData);\n      // handleSignupOrLogin();\n      navigate(\"/login\");\n    } catch (err) {\n      console.log(err)\n      console.error(\"Signup unsuccessful\");\n    }\n  };\n\n  return (\n    <div className=\"login\" onSubmit={handleSubmit}>\n      <div className=\"lwrapper\">\n        <div className=\"lleft\">\n          <h3 className=\"llogo\">Bunnybook</h3>\n          <span className=\"ldsc\">\n            Stay connected with those you love. Discover what's going on in the\n            world. Share and express what matters.\n          </span>\n        </div>\n        <div className=\"lright\">\n          <form method=\"POST\" action=\"#\" className=\"lbox\">\n            <input\n              id=\"username\"\n              name=\"username\"\n              type=\"text\"\n              className=\"linput\"\n              placeholder=\"Username\"\n              onChange={handleChange}\n            />\n            <input\n              className=\"linput\"\n              id=\"email\"\n              name=\"email\"\n              type=\"email\"\n              placeholder=\"Email\"\n              onChange={handleChange}\n            />\n\n            <input\n              id=\"password\"\n              name=\"password\"\n              type=\"password\"\n              className=\"linput\"\n              placeholder=\"Password\"\n              onChange={handleChange}\n            />\n\n            <input\n              id=\"password_confirmation\"\n              name=\"password_confirmation\"\n              type=\"password\"\n              className=\"linput\"\n              placeholder=\"Re-type Password\"\n              onChange={handleChange}\n            />\n             <button className=\"signupbutton\">Create a New Account</button>\n            \n          </form>\n        </div>\n      </div>\n    </div>\n  );\n};\n\nexport default Register;\n","/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/components/Profile/Profile.jsx",[],[],"/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/components/Rightbar/Rightbar.jsx",[],[],"/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/components/Sidebar/Sidebar.jsx",[],[],"/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/components/OnlineFriends/OnlineFriends.jsx",[],[],"/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/components/Post/Posts.jsx",[],[],"/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/components/CloseFriends/CloseFriends.jsx",["128"],[],"import React from 'react'\nimport '../Sidebar/Sidebar.css'\nimport {Users} from '../../seeds/Seeds'\n\n\nconst CloseFriends = ({user}) => {\n  return (\n    <div>\n    <li className=\"sbfriend\">\n        <img className=\"sbfriendpic\" src={user.profilePicture} alt=\"\" />\n        <span className=\"sbfriendname\">{user.username}</span>\n    </li>\n\n    </div>\n  )\n}\n\nexport default CloseFriends","/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/components/Post/Post.jsx",[],[],"/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/components/Navbar/Navbar.jsx",["129","130","131","132"],[],"import { Link, useNavigate } from \"react-router-dom\";\nimport {useState, useEffect} from 'react'\nimport \"./Navbar.css\";\nimport { Search, Person, Chat, Notifications } from \"@mui/icons-material\";\nimport SearchBar from \"../Search/SearchBar\";\n\nimport React from \"react\";\n\nconst Navbar = ({ user, handleLogout, setUser }) => {\n\n  // const [posts, setPosts] = useState([]);\n\n  // useEffect(() => {\n  //   fetch(process.env.REACT_APP_BUNNYBOOK_API_URL)\n  //     .then(res => res.json())\n  //     .then(posts => setPosts(posts));\n  // }, []);\n\n\n  return (\n    <div className=\"navbarContainer\">\n      <div className=\"navbarLeft\">\n        <span className=\"title\">bunnybook</span>\n      </div>\n      <div className=\"navbarCenter\">\n        <div className=\"search\">\n          <Search className=\"searchIcon\" />\n          {/* <SearchBar className=\"input\" data={posts}/> */}\n \n          <input placeholder=\"Search\" className=\"input\" />\n        </div>\n      </div>\n      <div className=\"navbarRight\">\n        <div className=\"navbarLinks\">\n          <Link to=\"/\">\n            <span className=\"navbarLink\">Home</span>{\" \"}\n          </Link>\n        </div>\n\n        <div className=\"navbarIcons\">\n          <div className=\"navbarIcon\">\n            <Person />\n            <span className=\"navbarIconNotification\">1</span>\n          </div>\n          <div className=\"navbarIcon\">\n          <Link to=\"/message\">\n          <Chat />\n          </Link>\n            <span className=\"navbarIconNotification\">5</span>\n          </div>\n          <div className=\"navbarIcon\">\n            <Notifications />\n            <span className=\"navbarIconNotification\">4</span>\n          </div>\n        </div>\n      </div>\n\n        { user ? <li>Welcome! </li> : <li> <Link to='/login'> Login </Link></li>}\n    { user ? <button onClick={handleLogout}>Log Out</button> : null}\n \n      <img\n        src=\"/assets/profile/mushu.jpg\"\n        alt=\"profile\"\n        className=\"navbarProfilePic\"\n      />\n    </div>\n\n  );\n};\n\nexport default Navbar;\n\n\n","/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/pages/Home/Home.jsx",[],[],"/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/pages/Status.jsx",[],[],"/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/components/Search/SearchBar.jsx",[],[],"/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/components/Messenger/ChatBox.jsx",[],[],"/Users/farhanahossain/Desktop/SEI/projects/Bunnybook/frontend/bunnybook/src/pages/Chat.jsx",[],[],{"ruleId":"133","severity":1,"message":"134","line":2,"column":23,"nodeType":"135","messageId":"136","endLine":2,"endColumn":27},{"ruleId":"133","severity":1,"message":"137","line":3,"column":9,"nodeType":"135","messageId":"136","endLine":3,"endColumn":14},{"ruleId":"133","severity":1,"message":"138","line":1,"column":16,"nodeType":"135","messageId":"136","endLine":1,"endColumn":27},{"ruleId":"133","severity":1,"message":"139","line":2,"column":9,"nodeType":"135","messageId":"136","endLine":2,"endColumn":17},{"ruleId":"133","severity":1,"message":"140","line":2,"column":19,"nodeType":"135","messageId":"136","endLine":2,"endColumn":28},{"ruleId":"133","severity":1,"message":"141","line":5,"column":8,"nodeType":"135","messageId":"136","endLine":5,"endColumn":17},"no-unused-vars","'Link' is defined but never used.","Identifier","unusedVar","'Users' is defined but never used.","'useNavigate' is defined but never used.","'useState' is defined but never used.","'useEffect' is defined but never used.","'SearchBar' is defined but never used."]